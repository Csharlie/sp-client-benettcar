# Spektra — Benettcar client environment
# Copy to .env and fill in your local values.
# Read infra/env/README.md for details.

# ── WordPress local site ──────────────────────────────────────
SPEKTRA_WP_URL=http://benettcar.local

# ── Client config path ────────────────────────────────────────
# Absolute path to this client's config.php on your machine.
# Example: D:\Projects\spektra\sp-clients\sp-benettcar\infra\config.php
SPEKTRA_CLIENT_CONFIG=

# ── Vite dev server origin ────────────────────────────────────
# Must match config.php allowed_origins for CORS to work.
VITE_DEV_ORIGIN=http://localhost:5174

# ── WAMP paths (Phase 4 setup) ───────────────────────────────
WAMP_WWW=D:\Local\wamp\www
WAMP_VHOST_DIR=D:\Local\wamp\bin\apache\apache2.4.65\conf\extra

# ── Debug ─────────────────────────────────────────────────────
SPEKTRA_WP_DEBUG=true
SPEKTRA_DEBUG=true
